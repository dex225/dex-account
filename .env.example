# Required
DATABASE_URL=postgres://user:password@localhost:5432/dex_account
DEX_JWT_SECRET=your-super-secret-jwt-key-min-32-chars
DEX_EMERGENCY_API_KEY=your-emergency-api-key
DEX_ALLOWED_ORIGINS=https://myaccount.example.com,https://app.example.com

# DEX Notifier Integration
DEX_NOTIFIER_URL=http://notifier:3000
DEX_NOTIFIER_API_KEY=your-notifier-api-key

# Optional
DEX_AUTO_MIGRATE=true
DEX_CLEANUP_INTERVAL_HOURS=1
RUST_LOG=dex_account=debug,tower_http=debug
